# Tikpan AI Studio 配置

# 运行环境：development / production
APP_ENV=production

# 网站公开访问地址，用于 OAuth 回调、邮件链接、后续 CDN 域名展示
PUBLIC_BASE_URL=https://www.example.com

# 你的 tikpan.com API Key（必填）
TIKPAN_API_KEY=sk-你的key

# 图片访问令牌密钥（部署时一定要改！）
TIKPAN_SECRET=改成随机字符串

# Flask 会话密钥
FLASK_SECRET=改成随机字符串

# 管理后台密码（默认 admin123）
ADMIN_PASSWORD=你的后台密码

# 如果前面有 Nginx / CDN / 负载均衡，生产环境建议开启
TRUST_PROXY=true
ALLOWED_ORIGINS=https://www.example.com

# 生产环境必须为 false；只有本地开发可以 true，让充值直接到账
ENABLE_DEV_RECHARGE=false
PAYMENT_PROVIDER=

# ==== 对象存储 / CDN（推荐部署时开启）====
# 关闭时生成文件保存在 web_app/outputs，本地开发方便；开启后文件上传 OSS，接口只返回 CDN URL。
OSS_ENABLED=false
OSS_BUCKET=你的bucket
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
OSS_KEY_ID=你的AccessKeyId
OSS_KEY_SECRET=你的AccessKeySecret
OSS_PREFIX=tikpan-web
OSS_CDN_DOMAIN=https://cdn.example.com

# ==== 邮件 ====
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_ACCOUNT=
SMTP_SENDER=
SMTP_PASSWORD=

# ==== 第三方登录 ====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://www.example.com

# 启动方式（二选一）：
# 开发：python app.py
# 生产：gunicorn -w 2 -b 127.0.0.1:5000 app:app
