# Tikpan API local development
PORT=8787
TIKPAN_STORE=memory
TIKPAN_PROVIDER_ADAPTER=mock
TIKPAN_WORKER_ENABLED=true

# Enable this when you are ready to call real upstream providers.
# TIKPAN_PROVIDER_ADAPTER=http

# Provider runtime secrets are keyed by provider id.
# Do not commit your real key. Copy this file to .env locally and fill your own token.
# PowerShell example:
# $env:TIKPAN_PROVIDER_SECRETS='{"cangyuan":"sk-your-cangyuan-token"}'
TIKPAN_PROVIDER_SECRETS={}

# Optional: protect /admin/* endpoints in local or production.
# TIKPAN_ADMIN_TOKEN=change-me

# PostgreSQL mode:
# TIKPAN_STORE=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/tikpan
